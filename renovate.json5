{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  enabledManagers: [
    'composer',
    'dockerfile',
    'github-actions'
  ],
  packageRules: [
    {
      matchManagers: [
        'composer'
      ],
      rangeStrategy: 'bump'
    },
    {
      matchManagers: [
        'dockerfile'
      ],
      matchPackageNames: [
        'ghcr.io/nayleen/php'
      ],
      matchUpdateTypes: [
        'digest'
      ],
      automerge: true,
      automergeStrategy: 'rebase',
      automergeType: 'pr',
      platformAutomerge: false
    },
  ],
}
